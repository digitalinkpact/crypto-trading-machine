# Binance.US API credentials (https://www.binance.us/usercenter/settings/api-management)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional LLM providers
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional: give the LLM reasoner internet context (CoinGecko + DuckDuckGo)
LLM_WEB_ENABLED=false
LLM_WEB_TIMEOUT_SECONDS=6
LLM_WEB_CACHE_TTL_SECONDS=900
# When true, the autopilot trading tick includes the LLM reasoner in the vote.
LLM_IN_TRADING_LOOP=false

# Runtime
ENV=dev
LOG_LEVEL=INFO

# ── Auth / sessions / email ──────────────────────────────────────────────
# Public URL used in verification + reset emails. Change for prod.
BASE_URL=http://localhost:8000
# Long random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Lockout policy
AUTH_MAX_FAILED=5
AUTH_LOCKOUT_MINUTES=15
AUTH_SESSION_HOURS=12
AUTH_REMEMBER_DAYS=30
AUTH_TOKEN_MINUTES=60
# Comma-separated IPs or CIDRs that skip the login wall (e.g. your office IP).
# Leave blank to require login from everywhere.
AUTH_IP_ALLOWLIST=
# Set true when behind a reverse proxy that terminates TLS (nginx/caddy/cloudflare).
FORCE_HTTPS=false

# SMTP for outbound email (verification + password reset).
# Gmail example: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_STARTTLS=true
# SMTP_USER=you@gmail.com SMTP_PASSWORD=<app password>
# SMTP_FROM="Crypto Bot <you@gmail.com>"
# If left blank, emails are logged to the journal instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# Trading safety — KEEP TRUE UNTIL YOU MEAN IT
DRY_RUN=true
PAPER_TRADING=true

# Risk
MAX_POSITION_PCT=0.10
MAX_PORTFOLIO_RISK_PCT=0.25
KELLY_FRACTION_CAP=0.25

# ML learning loop
ML_LEARNING_ENABLED=true
ML_SIGNAL_HORIZON_MINUTES=240
ML_MIN_TRAINING_SAMPLES=200
ML_MIN_NEW_LABELS=50

# Storage
DATA_CACHE_DIR=./data/cache
