# Dynamic symbol discovery
USE_DYNAMIC_SYMBOLS=true
SYMBOLS_CACHE_MINUTES=60
# Universe filters (when USE_DYNAMIC_SYMBOLS=true). Trades every Binance.US
# USDT pair except leveraged ETF tokens and stablecoin->stablecoin pairs.
EXCLUDE_LEVERAGED_TOKENS=true
# 24h quote-volume floor in USDT; 0 = all coins. Raise (e.g. 1000000) to skip
# thin/illiquid coins that have high market-order slippage risk.
MIN_QUOTE_VOLUME_USDT=0

# ── Liquidity-ranked pairlist (staged universe filter) ──────────────────
# When LIQUIDITY_PAIRLIST_ENABLED=true, the universe is built by a staged
# pipeline (top-N by volume -> $ volume floor -> listing age -> spread cap ->
# top-N survivors) and SUPERSEDES MAX_SYMBOLS / MIN_QUOTE_VOLUME_USDT above.
# NOTE: MAX_SPREAD_PERCENT is a PERCENT (0.50 = 0.50%); the execution-time
# order-book gate (MAX_SPREAD_PCT) is a FRACTION (0.005 = 0.50%).
# SCALE NOTE: defaults are tuned for Binance.US (a small exchange) — even
# BTCUSDT trades only ~$2-3M/24h, so a $5M floor would zero the universe.
LIQUIDITY_PAIRLIST_ENABLED=true
UNIVERSE_SIZE=75
MIN_24H_VOLUME=1000
MAX_SPREAD_PERCENT=0.50
MIN_DAYS_LISTED=15
FINAL_PAIRLIST_SIZE=50
VOLUME_SORT_KEY=quoteVolume
VOLUME_REFRESH_SECONDS=1800

# API rate limit/backoff
API_RETRY_ATTEMPTS=3
API_RETRY_BACKOFF_BASE=2
# Binance.US API credentials (https://www.binance.us/usercenter/settings/api-management)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional LLM providers
# Provider: deepseek | openai | groq | gemini | github | none
# Whichever you pick MUST have its key/token set below, or the LLM reasoner
# silently disables (every vote becomes HOLD/0.0). main.py warns on boot if
# LLM_IN_TRADING_LOOP=true but the chosen provider has no credential.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
# GitHub Models (free, rate-limited). Required only if LLM_PROVIDER=github.
# PAT with `models:read` scope: https://github.com/settings/tokens
# NOTE: GitHub Codespaces auto-injects a GITHUB_TOKEN env var that overrides an
# empty value here — so github "works" in a codespace but dies on a plain VPS.
GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-4o

# Optional: give the LLM reasoner internet context (Binance.US + DuckDuckGo)
LLM_WEB_ENABLED=true
LLM_WEB_TIMEOUT_SECONDS=6
LLM_WEB_CACHE_TTL_SECONDS=900
# When true, the autopilot trading tick includes the LLM reasoner in the vote.
LLM_IN_TRADING_LOOP=true

# ── Information-quality upgrades ─────────────────────────────────────────
# ML quality gate: drop BUY/SELL signals the learned model rates below the
# threshold win-probability. Fail-open until a model has trained.
ML_GATE_ENABLED=true
ML_GATE_THRESHOLD=0.50

# Live price stream (websocket). Keeps a sub-second last-price cache so
# execution isn't 15 min stale. OHLCV history still comes from REST polling.
LIVE_PRICE_ENABLED=true
LIVE_PRICE_MAX_AGE_SECONDS=30

# Order-book / liquidity gate (reject thin or wide books before entry).
ORDERBOOK_GATE_ENABLED=true
ORDERBOOK_DEPTH_LIMIT=10
MAX_SPREAD_PCT=0.005
MIN_DEPTH_TRADE_MULTIPLE=2.0
ORDERBOOK_NEAR_PCT=0.001

# Derivatives context (funding + open interest). Binance.US has no futures,
# so this reads PUBLIC Binance global-futures data for reference only. It may
# be geofenced in the US — keep OFF unless you have access. Never trades there.
DERIVATIVES_DATA_ENABLED=false
DERIVATIVES_BASE_URL=https://fapi.binance.com
DERIVATIVES_TIMEOUT_SECONDS=6
DERIVATIVES_CACHE_TTL_SECONDS=300
FUNDING_MIN_PCT=-0.0001

# Dynamic confidence threshold (online regime model). Nudges the entry bar
# based on recently-resolved trades; bounded so it can't override technicals.
DYNAMIC_THRESHOLD_ENABLED=true
DYNAMIC_THRESHOLD_MAX_DELTA=0.10
ONLINE_REGIME_MIN_SAMPLES=30

# On-chain whale flows (optional). Requires a Glassnode API key. Off by default.
ONCHAIN_ENABLED=false
GLASSNODE_API_KEY=
ONCHAIN_TIMEOUT_SECONDS=6
ONCHAIN_CACHE_TTL_SECONDS=1800
ONCHAIN_INFLOW_SPIKE_Z=2.0

# Runtime
ENV=dev
LOG_LEVEL=INFO

# ── Auth / sessions / email ──────────────────────────────────────────────
# Public URL used in verification + reset emails. Change for prod.
BASE_URL=http://localhost:8000
# Long random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Lockout policy
AUTH_MAX_FAILED=5
AUTH_LOCKOUT_MINUTES=15
AUTH_SESSION_HOURS=12
AUTH_REMEMBER_DAYS=30
AUTH_TOKEN_MINUTES=60
# Comma-separated IPs or CIDRs that skip the login wall (e.g. your office IP).
# Leave blank to require login from everywhere.
AUTH_IP_ALLOWLIST=
# Set true when behind a reverse proxy that terminates TLS (nginx/caddy/cloudflare).
FORCE_HTTPS=false

# SMTP for outbound email (verification + password reset).
# Gmail example: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_STARTTLS=true
# SMTP_USER=you@gmail.com SMTP_PASSWORD=<app password>
# SMTP_FROM="Crypto Bot <you@gmail.com>"
# If left blank, emails are logged to the journal instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# Trading mode
# LIVE_MODE=true forces live trading in-process and overrides stale
# PAPER_TRADING/DRY_RUN values from older env files.
LIVE_MODE=false
# Trading safety — KEEP TRUE UNTIL YOU MEAN IT
DRY_RUN=true
PAPER_TRADING=true

# Risk
MAX_POSITION_PCT=0.05
MAX_PORTFOLIO_RISK_PCT=0.25
KELLY_FRACTION_CAP=0.25
MAX_OPEN_POSITIONS=25

# ML learning loop
ML_LEARNING_ENABLED=true
ML_SIGNAL_HORIZON_MINUTES=240
ML_MIN_TRAINING_SAMPLES=200
ML_MIN_NEW_LABELS=50

# (ML quality gate is configured in the information-quality block above —
#  ML_GATE_ENABLED / ML_GATE_THRESHOLD. Don't set them twice: dotenv keeps the
#  LAST occurrence, which would silently override the intended value.)

# Storage
DATA_CACHE_DIR=./data/cache

# ── Binance.US spot trading fees (fractions: 0.001 = 0.10%) ───────────────
# These feed position sizing, paper fills, closed-trade PnL, the ML win/loss
# labels, and the backtester, so they should match your ACTUAL fee tier.
# Don't guess: after adding API keys, run `python -m scripts.sync_fees` to pull
# your real maker/taker rates from the account and write them here.
BINANCE_MAKER_FEE=0.0040
BINANCE_TAKER_FEE=0.0060
# How much a matured signal must clear, on top of round-trip taker fees, to be
# labeled a "win" for ML training (0.0010 = 0.10% slippage buffer).
ML_LABEL_SLIPPAGE_PCT=0.0010
