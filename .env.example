# Binance.US API credentials (https://www.binance.us/usercenter/settings/api-management)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional LLM providers
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Runtime
ENV=dev
LOG_LEVEL=INFO

# Optional app access guard (HTTP Basic). Set both to enable.
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=

# Trading safety — KEEP TRUE UNTIL YOU MEAN IT
DRY_RUN=true
PAPER_TRADING=true

# Risk
MAX_POSITION_PCT=0.10
MAX_PORTFOLIO_RISK_PCT=0.25
KELLY_FRACTION_CAP=0.25

# ML learning loop
ML_LEARNING_ENABLED=true
ML_SIGNAL_HORIZON_MINUTES=240
ML_MIN_TRAINING_SAMPLES=200
ML_MIN_NEW_LABELS=50

# Storage
DATA_CACHE_DIR=./data/cache
