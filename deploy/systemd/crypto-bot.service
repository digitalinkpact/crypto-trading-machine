[Unit]
Description=Crypto Trading Machine API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/crypto-trading-machine
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/crypto-trading-machine/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
